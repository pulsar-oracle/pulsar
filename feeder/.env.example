# Stellar network: "testnet" or "mainnet"
STELLAR_NETWORK=testnet

# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Pulsar aggregator contract ID (deployed)
PULSAR_CONTRACT_ID=

# Feeder node Stellar secret key (funded account)
FEEDER_SECRET_KEY=

# How often to submit data (seconds)
SUBMISSION_INTERVAL=60

# Comma-separated list of feeds to serve: XLM_USD,BTC_USD,ETH_USD
ACTIVE_FEEDS=XLM_USD,BTC_USD
